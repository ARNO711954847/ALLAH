set -Eeuo pipefail
IFS=$'\n\t'

# Fix for curl | bash stdin redirect
if [[ ! -t 0 ]]; then
    exec 0</dev/tty
fi

# Global Constants
export ARNO_VERSION="1.0.0"
export ARNO_LOG_FILE="/var/log/arno-installer.log"
export ARNO_PANEL_PATH="/var/www/pterodactyl"

# Color Codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
RESET='\033[0m'

# Helper UI Functions
arno_log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "${ARNO_LOG_FILE}" 2>/dev/null || true
}

ui_print_success() { echo -e "${GREEN}[SUCCESS] $*${RESET}"; arno_log "SUCCESS: $*"; }
ui_print_warning() { echo -e "${YELLOW}[WARNING] $*${RESET}"; arno_log "WARNING: $*"; }
ui_print_error()   { echo -e "${RED}[ERROR] $*${RESET}"; arno_log "ERROR: $*"; }
ui_print_info()    { echo -e "${BLUE}[INFO] $*${RESET}"; arno_log "INFO: $*"; }

ui_show_splash() {
    clear
    # ARNO Text ASCII Art Logo
    echo -e "${CYAN}"
    echo "    █████╗ ██████╗ ███╗   ██╗ ██████╗ "
    echo "   ██╔══██╗██╔══██╗████╗  ██║██╔═══██╗"
    echo "   ███████║██████╔╝██╔██╗ ██║██║   ██║"
    echo "   ██╔══██║██╔══██╗██║╚██╗██║██║   ██║"
    echo "   ██║  ██║██║  ██║██║ ╚████║╚██████╔╝"
    echo "   ╚═╝  ╚═╝╚═╝  ╚═╝╚═╝  ╚═══╝ ╚═════╝ "
    echo -e "${RESET}"
    echo -e "${BLUE}============================================================${RESET}"
    echo -e "${YELLOW}                 ARNO INSTALLER v${ARNO_VERSION}               ${RESET}"
    echo -e "${YELLOW}       Pterodactyl Panel & Wings Automatic Installer        ${RESET}"
    echo -e "${BLUE}============================================================${RESET}"
    echo ""
}

ui_run_startup_checks() {
    ui_show_splash
    ui_print_info "Running system checks..."
    
    # Root Check
    if [[ $EUID -ne 0 ]]; then
        ui_print_error "This script must be run as root (sudo)."
        exit 1
    fi
    
    # OS Detection
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        export OS_NAME=$ID
        export OS_VERSION=$VERSION_ID
    else
        ui_print_error "Unsupported Operating System."
        exit 1
    fi

    if [[ "$OS_NAME" != "ubuntu" && "$OS_NAME" != "debian" ]]; then
        ui_print_warning "This script is optimized for Ubuntu/Debian. Continuing anyway..."
    fi
    
    # Init Log File
    : > "${ARNO_LOG_FILE}" 2>/dev/null || true
    chmod 600 "${ARNO_LOG_FILE}" 2>/dev/null || true
    ui_print_success "System compatibility check passed."
    sleep 1
}

# Dependencies Installation
install_common_deps() {
    ui_print_info "Updating package lists and installing dependencies..."
    apt-get update -y && apt-get install -y lsb-release ca-certificates curl tar unzip git redis-server software-properties-common mariadb-server nginx ufw >/dev/null 2>&1
}

# --- Pterodactyl Panel Installation Logic ---
panel_install_flow() {
    ui_show_splash
    ui_print_info "Starting Pterodactyl Panel Installation..."
    
    install_common_deps

    # 1. Install PHP 8.2 (Required for Pterodactyl)
    ui_print_info "Installing PHP 8.2 and extensions..."
    if [[ "$OS_NAME" == "ubuntu" ]]; then
        add-apt-repository -y ppa:ondrej/php >/dev/null 2>&1
        apt-get update -y >/dev/null 2>&1
    fi
    apt-get install -y php8.2 php8.2-common php8.2-cli php8.2-gd php8.2-mysql php8.2-mbstring php8.2-bcmath php8.2-xml php8.2-curl php8.2-zip php8.2-intl php8.2-sqlite3 php8.2-fpm php8.2-redis >/dev/null 2>&1

    # 2. Install Composer
    ui_print_info "Installing Composer..."
    curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer >/dev/null 2>&1

    # 3. Download Panel Files
    ui_print_info "Downloading Pterodactyl Panel files..."
    mkdir -p "${ARNO_PANEL_PATH}" && cd "${ARNO_PANEL_PATH}"
    curl -Lo panel.tar.gz https://github.com/pterodactyl/panel/releases/latest/download/panel.tar.gz >/dev/null 2>&1
    tar -xzvf panel.tar.gz >/dev/null 2>&1
    chmod -R 755 storage/* bootstrap/cache/

    # 4. Setup Database
    ui_print_info "Configuring MariaDB Database..."
    DB_PASSWORD=$(head /dev/urandom | tr -dc A-Za-z0-9 | head -c 16 ; echo '')
    mysql -e "CREATE DATABASE IF NOT EXISTS ptero;"
    mysql -e "CREATE USER IF NOT EXISTS 'ptero'@'127.0.0.1' IDENTIFIED BY '${DB_PASSWORD}';"
    mysql -e "GRANT ALL PRIVILEGES ON ptero.* TO 'ptero'@'127.0.0.1' WITH GRANT OPTION;"
    mysql -e "FLUSH PRIVILEGES;"

    # 5. Environment Configuration
    ui_print_info "Setting up environment configuration..."
    cp .env.example .env
    composer install --no-dev --optimize-autoloader --no-interaction >/dev/null 2>&1
    php artisan key:generate --force --no-interaction

    ui_print_warning "Database Password generated: ${DB_PASSWORD}"
    ui_print_warning "Please run standard 'php artisan ptero:environment' to complete setup manually if needed."
    
    # 6. Permissions & Crontab
    chown -R www-data:www-data "${ARNO_PANEL_PATH}"/*
    (crontab -l 2>/dev/null; echo "* * * * * php ${ARNO_PANEL_PATH}/artisan schedule:run >> /dev/null 2>&1") | crontab -

    # 7. Systemd Queue Worker
    ui_print_info "Creating Queue Worker Service..."
    cat <<EOF > /etc/systemd/system/pteroq.service
[Unit]
Description=Pterodactyl Queue Worker
After=redis-server.service

[Service]
User=www-data
Group=www-data
Restart=always
ExecStart=/usr/bin/php ${ARNO_PANEL_PATH}/artisan queue:work --queue=high,standard,low --sleep=3 --tries=3
StartLimitInterval=180
StartLimitBurst=30

[Install]
WantedBy=multi-user.target
EOF
    systemctl enable --now pteroq.service >/dev/null 2>&1
    systemctl enable --now redis-server >/dev/null 2>&1

    ui_print_success "Pterodactyl Panel files installed successfully!"
    read -p "Press [Enter] to return to main menu..."
}

# --- Pterodactyl Wings Installation Logic ---
wings_install_flow() {
    ui_show_splash
    ui_print_info "Starting Pterodactyl Wings Installation..."

    # 1. Install Docker
    ui_print_info "Installing Docker Engine..."
    curl -sSL https://get.docker.com/ | CHANNEL=stable bash >/dev/null 2>&1
    systemctl enable --now docker

    # 2. Install Wings Binary
    ui_print_info "Downloading Wings Binary..."
    mkdir -p /etc/pterodactyl
    curl -L -o /usr/local/bin/wings "https://github.com/pterodactyl/wings/releases/latest/download/wings_linux_amd64" >/dev/null 2>&1
    chmod +x /usr/local/bin/wings

    # 3. Systemd Service for Wings
    ui_print_info "Creating Wings Systemd Service..."
    cat <<EOF > /etc/systemd/system/wings.service
[Unit]
Description=Pterodactyl Wings Daemon
After=docker.service
Requires=docker.service

[Service]
User=root
WorkingDirectory=/etc/pterodactyl
LimitNOFILE=1048576
LimitNPROC=1048576
LimitMEMLOCK=infinity
CapabilityBoundingSet=CAP_CHOWN CAP_DAC_OVERRIDE CAP_FOWNER CAP_SYS_CHROOT CAP_SETGID CAP_SETUID CAP_SETFCAP CAP_NET_BIND_SERVICE CAP_SYS_MODULE CAP_SYS_RESOURCE
SecureBits=keep-caps
AmbientCapabilities=CAP_CHOWN CAP_DAC_OVERRIDE CAP_FOWNER CAP_SYS_CHROOT CAP_SETGID CAP_SETUID CAP_SETFCAP CAP_NET_BIND_SERVICE CAP_SYS_MODULE CAP_SYS_RESOURCE
NoNewPrivileges=no
ExecStart=/usr/local/bin/wings
Restart=always
StartLimitInterval=180
StartLimitBurst=30

[Install]
WantedBy=multi-user.target
EOF
    systemctl daemon-reload
    systemctl enable wings >/dev/null 2>&1

    ui_print_success "Wings installed! Please place your 'config.yml' inside /etc/pterodactyl/ and run 'systemctl start wings'"
    read -p "Press [Enter] to return to main menu..."
}

ui_show_main_menu() {
    ui_show_splash
    echo -e "${CYAN}1)${RESET} Install Pterodactyl Panel"
    echo -e "${CYAN}2)${RESET} Install Pterodactyl Wings"
    echo -e "${CYAN}3)${RESET} Exit Installer"
    echo ""
}

# Main Bootstrap
arno_main() {
    ui_run_startup_checks
    
    while true; do
        ui_show_main_menu
        read -p "Select an option [1-3]: " choice
        case "$choice" in
            1) panel_install_flow ;;
            2) wings_install_flow ;;
            3) ui_print_info "Thank you for using ARNO Installer. Goodbye!"; break ;;
            *) ui_print_warning "Invalid choice, please select 1, 2, or 3." && sleep 2 ;;
        esac
    done
}

arno_main "$@"
