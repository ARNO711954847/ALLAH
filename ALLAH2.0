#!/bin/bash

# Exit immediately if a command exits with a non-zero status
set -e

# Display ARNO Logo
cat << "EOF"
    _    ____  _   _  ___  
   / \  |  _ \| \ | |/ _ \ 
  / _ \ | |_) |  \| | | | |
 / ___ \|  _ <| |\  | |_| |
/_/   \_\_| \_\_| \_|\___/ 
                           
EOF

echo "Starting the panel installation process..."
echo "MADE BY - JISHNU | panel info"
echo "----------------------------------------"

# Update package index and install curl
echo "Updating package index..."
sudo apt update

echo "Installing curl..."
sudo apt install curl -y

# Setup and install Node.js 20.x
echo "Setting up Node.js repository..."
curl -fsSL https://deb.nodesource.com/setup_20.x | sudo -E bash -

echo "Installing Node.js..."
sudo apt install -y nodejs 

# Install PM2 globally
echo "Installing PM2 globally..."
sudo npm install -g pm2

# Clone the repository and install the panel
echo "Cloning the Jtg panel repository..."
git clone https://github.com/JishnuTheGamer/Jtg

echo "Navigating to Jtg directory..."
# If cd fails, the script will exit to prevent running npm commands in the wrong directory
cd Jtg || exit

echo "Installing project dependencies..."
npm i 

echo "Creating user..."
npm run createuser

echo "Building the panel..."
npm run build

echo "Starting the panel with PM2..."
pm2 start ecosystem.config.cjs

echo "----------------------------------------"
echo "Installation complete! Your panel is now running."
