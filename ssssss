#!/bin/bash

# Define ANSI color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color (Reset)

# Clear the terminal screen for a clean output
clear

# Display the "ARNO" ASCII Logo in Cyan
echo -e "${CYAN}"
echo "    _    ____  _   _  ___  "
echo "   / \  |  _ \| \ | |/ _ \ "
echo "  / _ \ | |_) |  \| | | | |"
echo " / ___ \|  _ <| |\  | |_| |"
echo "/_/   \_\_| \_\_| \_|\___/ "
echo -e "${NC}"

# Display colorful status messages
echo -e "${MAGENTA}=====================================${NC}"
echo -e "${YELLOW}   Initializing ARNO Installer...    ${NC}"
echo -e "${MAGENTA}=====================================${NC}"
echo -e ""
echo -e "${GREEN}[INFO]${NC} Downloading and starting the Pterodactyl installation script..."
echo -e ""

# Execute the original Pterodactyl installer command
bash <(curl -s https://pterodactyl-installer.se)

# Final message after the installer finishes (or exits)
echo -e ""
echo -e "${GREEN}[SUCCESS]${NC} Script execution completed."
